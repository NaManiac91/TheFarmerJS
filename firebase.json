{
  "hosting": {
    "site": "thefarmer-d8d99",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/server/**",
      "Deploy/**",
      "app/**",
      "build/**",
      "gradle/**",
      "*.apk",
      "*.aab",
      "*.idsig",
      "**/*.keystore",
      "**/serviceAccountKey.json",
      "**/.env",
      "**/.env.*",
      "twa-manifest.json",
      "manifest-checksum.txt"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "scripts/server"
  }
}
